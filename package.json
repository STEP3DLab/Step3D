{
  "name": "step3d-landing",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint:html": "htmlhint index.html",
    "lint:css": "stylelint \"index.html\"",
    "format:check": "prettier --check \"index.html\" \"README.md\"",
    "format": "prettier --write \"index.html\" \"README.md\"",
    "quality": "npm run lint:html && npm run lint:css && npm run format:check"
  },
  "devDependencies": {
    "htmlhint": "^1.7.1",
    "postcss-html": "^1.8.0",
    "prettier": "^3.5.3",
    "stylelint": "^16.15.0",
    "stylelint-config-recommended": "^14.0.1"
  }
}
